    <!-- ══════════════════════════════════════════
         ROTORS (revolute — generate lift)
         z = 0.03 (frame top) + 0.032 (motor) = 0.062m
         Order matches CA_ROTOR params in airframe:
           rotor_0: front-left   CCW  (+x, +y)
           rotor_1: rear-right   CCW  (-x, -y)
           rotor_2: front-right  CW   (+x, -y)
           rotor_3: rear-left    CW   (-x, +y)
    ══════════════════════════════════════════ -->

    <link name="rotor_0">
      <!-- front-left CCW — matches CA_ROTOR0 (+x,+y) -->
      <self_collide>false</self_collide>
      <gravity>false</gravity>
      <pose>0.16087 -0.16087 0.062 0 0 0</pose>
      <self_collide>false</self_collide>
      <inertial>
        <mass>0.016076923076923075</mass>
        <inertia><ixx>3.8464910483993325e-07</ixx><ixy>0</ixy><ixz>0</ixz><iyy>2.6115851691700804e-05</iyy><iyz>0</iyz><izz>2.649858234714004e-05</izz></inertia>
      </inertial>
      <visual name="rotor_0_visual">
        <pose>-0.022 -0.146 -0.016 0 0 0</pose>
        <geometry><mesh><scale>0.846 0.846 0.846</scale><uri>model://x500_base/meshes/1345_prop_ccw.stl</uri></mesh></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
      <visual name="rotor_0_bell">
        <pose>0 0 -0.032 0 0 0</pose>
        <geometry><mesh><scale>1 1 1</scale><uri>model://x500_base/meshes/5010Bell.dae</uri></mesh></geometry>
      </visual>
      <collision name="rotor_0_collision">
        <geometry><box><size>0.279 0.017 0.001</size></box></geometry>
        <surface><contact><ode><min_depth>0.001</min_depth><max_vel>0</max_vel></ode></contact><friction><ode/></friction></surface>
      </collision>
    </link>
    <joint name="rotor_0_joint" type="revolute">
      <parent>base_link</parent><child>rotor_0</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e+16</lower><upper>1e+16</upper></limit><dynamics><spring_reference>0</spring_reference><spring_stiffness>0</spring_stiffness></dynamics></axis>
