    <!-- Single shared ToF link, centered at drone origin -->
    <link name="tof_array_link">
      <inertial>
        <mass>0.005</mass>
        <inertia><ixx>1e-6</ixx><ixy>0</ixy><ixz>0</ixz>
                <iyy>1e-6</iyy><iyz>0</iyz><izz>1e-6</izz></inertia>
      </inertial>
      <self_collide>false</self_collide>
      <gravity>false</gravity>
    </link>
    <joint name="tof_array_joint" type="fixed">
      <parent>base_link</parent>
      <child>tof_array_link</child>
    </joint>

      <!-- ToF 0: front, 0° -->
    <link name="tof_0_link">
      <pose>0.25 0 0  0 0 0</pose>          <!-- front, 0° yaw -->
      <inertial><mass>0.0001</mass>
        <inertia><ixx>1e-9</ixx><ixy>0</ixy><ixz>0</ixz>
                <iyy>1e-9</iyy><iyz>0</iyz><izz>1e-9</izz></inertia>
      </inertial>
      <sensor name="tof_0" type="depth_camera">         <!-- offset from tof_array_link -->
        <gz_frame_id>tof_0_link</gz_frame_id>
        <always_on>1</always_on>
        <visualize>true</visualize>
        <update_rate>20</update_rate>
        <camera>
          <horizontal_fov>1.2217</horizontal_fov>
          <image><width>100</width><height>100</height><format>R_FLOAT32</format></image>
          <clip><near>0.15</near><far>3.0</far></clip>
        </camera>
        <topic>tof_0_depth</topic>
      </sensor>
    </link>
    <joint name="tof_0_joint" type="fixed">
      <parent>tof_array_link</parent>   <!-- parent is tof_array_link, not base_link -->
      <child>tof_0_link</child>
    </joint>

      <!-- ToF 1: front-left, 72° -->
    <link name="tof_1_link">
      <pose>0.077 0.236 0  0 0 1.2566</pose> <!-- front-left, 72° yaw -->
      <inertial><mass>0.0001</mass>
        <inertia><ixx>1e-9</ixx><ixy>0</ixy><ixz>0</ixz>
                <iyy>1e-9</iyy><iyz>0</iyz><izz>1e-9</izz></inertia>
      </inertial>

      <sensor name="tof_1" type="depth_camera">
        <gz_frame_id>tof_1_link</gz_frame_id>
        <always_on>1</always_on>
        <visualize>true</visualize>
        <update_rate>20</update_rate>
        <camera>
          <horizontal_fov>1.2217</horizontal_fov>
          <image><width>100</width><height>100</height><format>R_FLOAT32</format></image>
          <clip><near>0.15</near><far>3.0</far></clip>
        </camera>
        <topic>tof_1_depth</topic>
      </sensor>
    </link>
    <joint name="tof_1_joint" type="fixed">
      <parent>tof_array_link</parent>
      <child>tof_1_link</child>
    </joint>

    <link name="tof_2_link">
      <pose>-0.202 0.147 0  0 0 2.5133</pose> <!-- rear-left, 144° yaw -->
      <inertial><mass>0.0001</mass>
        <inertia><ixx>1e-9</ixx><ixy>0</ixy><ixz>0</ixz>
                <iyy>1e-9</iyy><iyz>0</iyz><izz>1e-9</izz></inertia>
      </inertial>

      <!-- ToF 2: rear-left, 144° -->
      <sensor name="tof_2" type="depth_camera">
        <gz_frame_id>tof_2_link</gz_frame_id>
        <always_on>1</always_on>
        <visualize>true</visualize>
        <update_rate>20</update_rate>
        <camera>
          <horizontal_fov>1.2217</horizontal_fov>
          <image><width>100</width><height>100</height><format>R_FLOAT32</format></image>
          <clip><near>0.15</near><far>3.0</far></clip>
        </camera>
        <topic>tof_2_depth</topic>
      </sensor>
    </link>
    <joint name="tof_2_joint" type="fixed">
      <parent>tof_array_link</parent>
      <child>tof_2_link</child>
    </joint>

    <link name="tof_3_link">
      <pose>-0.202 -0.147 0  0 0 -2.5133</pose> <!-- rear-right, -144° yaw -->
      <inertial><mass>0.0001</mass>
        <inertia><ixx>1e-9</ixx><ixy>0</ixy><ixz>0</ixz>
                <iyy>1e-9</iyy><iyz>0</iyz><izz>1e-9</izz></inertia>
      </inertial>

      <!-- ToF 3: rear-right, -144° -->
      <sensor name="tof_3" type="depth_camera">
        <gz_frame_id>tof_3_link</gz_frame_id>
        <always_on>1</always_on>
        <visualize>true</visualize>
        <update_rate>20</update_rate>
        <camera>
          <horizontal_fov>1.2217</horizontal_fov>
          <image><width>100</width><height>100</height><format>R_FLOAT32</format></image>
          <clip><near>0.15</near><far>3.0</far></clip>
        </camera>
        <topic>tof_3_depth</topic>
      </sensor>
    </link>
    <joint name="tof_3_joint" type="fixed">
      <parent>tof_array_link</parent>
      <child>tof_3_link</child>
    </joint>

    <link name="tof_4_link">
      <pose>0.077 -0.236 0  0 0 -1.2566</pose> <!-- front-right, -72° yaw -->
      <inertial><mass>0.0001</mass>
        <inertia><ixx>1e-9</ixx><ixy>0</ixy><ixz>0</ixz>
                <iyy>1e-9</iyy><iyz>0</iyz><izz>1e-9</izz></inertia>
      </inertial>

      <!-- ToF 4: front-right, -72° -->
      <sensor name="tof_4" type="depth_camera">
        <gz_frame_id>tof_4_link</gz_frame_id>
        <always_on>1</always_on>
        <visualize>true</visualize>
        <update_rate>20</update_rate>
        <camera>
          <horizontal_fov>1.2217</horizontal_fov>
          <image><width>100</width><height>100</height><format>R_FLOAT32</format></image>
          <clip><near>0.15</near><far>3.0</far></clip>
        </camera>
        <topic>tof_4_depth</topic>
      </sensor>

    </link>
    <joint name="tof_4_joint" type="fixed">
      <parent>tof_array_link</parent>
      <child>tof_4_link</child>
    </joint>

    <!-- ══════════════════════════════════════════
         RGBD FRONT CAMERA
    ══════════════════════════════════════════ -->
    <link name="rgbd_cam_link">
      <inertial>
        <mass>0.001</mass>
        <inertia><ixx>1e-6</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1e-6</iyy><iyz>0</iyz><izz>1e-6</izz></inertia>
      </inertial>

      <pose>0.2 0 0.02 0 0 0</pose>

      <collision name="rgbd_cam_link/collision">
        <pose>0.00358 -0.03 .014 0 0 0</pose>
        <geometry>
          <box>
            <size>0.0175 0.091 0.028</size>
          </box>
        </geometry>
      </collision>

      <sensor name="rgbd_camera_rgb" type="camera">
        <gz_frame_id>rgbd_cam_link</gz_frame_id>
        <always_on>1</always_on><update_rate>30</update_rate>
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image><width>1280</width><height>720</height></image>
          <clip><near>0.1</near><far>10.0</far></clip>
          <noise><type>gaussian</type><mean>0</mean><stddev>0.005</stddev></noise>
        </camera>
        <visualize>true</visualize>
        <topic>rgbd_image</topic>
      </sensor>

      <sensor name="rgbd_camera" type="depth_camera">
        <gz_frame_id>rgbd_cam_link</gz_frame_id>
        <always_on>1</always_on><update_rate>30</update_rate>
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image><width>1280</width><height>720</height><format>R_FLOAT32</format></image>
          <clip><near>0.1</near><far>10.0</far></clip>
          <noise><type>gaussian</type><mean>0</mean><stddev>0.005</stddev></noise>
        </camera>
        <visualize>true</visualize>
        <topic>rgbd_depth</topic>
      </sensor>
    </link>
    <joint name="rgbd_cam_joint" type="fixed">
      <parent>base_link</parent><child>rgbd_cam_link</child>
    </joint>

    <!-- ══════════════════════════════════════════
         STEREO IR PAIR (mirrors Intel RealSense D415)
         HFOV 65° (1.134 rad), 1280×720 mono, 30 Hz,
         baseline 55 mm (cameras at ±0.0275 m)
    ══════════════════════════════════════════ -->
    <link name="stereo_left_cam_link">
      <inertial>
        <mass>0.001</mass>
        <inertia><ixx>1e-6</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1e-6</iyy><iyz>0</iyz><izz>1e-6</izz></inertia>
      </inertial>

      <pose>0.2 0.0275 0.02 0 0 0</pose>

      <sensor name="stereo_left_camera" type="camera">
        <gz_frame_id>stereo_left_cam_link</gz_frame_id>
        <always_on>1</always_on><update_rate>30</update_rate>
        <camera>
          <horizontal_fov>1.134</horizontal_fov>
          <image><width>1280</width><height>720</height><format>L8</format></image>
          <clip><near>0.1</near><far>10.0</far></clip>
          <noise><type>gaussian</type><mean>0</mean><stddev>0.005</stddev></noise>
        </camera>
        <visualize>true</visualize>
        <topic>stereo_left_image</topic>
      </sensor>
    </link>
    <joint name="stereo_left_cam_joint" type="fixed">
      <parent>base_link</parent><child>stereo_left_cam_link</child>
    </joint>

    <link name="stereo_right_cam_link">
      <inertial>
        <mass>0.001</mass>
        <inertia><ixx>1e-6</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1e-6</iyy><iyz>0</iyz><izz>1e-6</izz></inertia>
      </inertial>

      <pose>0.2 -0.0275 0.02 0 0 0</pose>

      <sensor name="stereo_right_camera" type="camera">
        <gz_frame_id>stereo_right_cam_link</gz_frame_id>
        <always_on>1</always_on><update_rate>30</update_rate>
        <camera>
          <horizontal_fov>1.134</horizontal_fov>
          <image><width>1280</width><height>720</height><format>L8</format></image>
          <clip><near>0.1</near><far>10.0</far></clip>
          <noise><type>gaussian</type><mean>0</mean><stddev>0.005</stddev></noise>
        </camera>
        <visualize>true</visualize>
        <topic>stereo_right_image</topic>
      </sensor>
    </link>
    <joint name="stereo_right_cam_joint" type="fixed">
      <parent>base_link</parent><child>stereo_right_cam_link</child>
    </joint>

    <!-- ══════════════════════════════════════════
         BOTTOM DEPTH CAMERA
    ══════════════════════════════════════════ -->
    <link name="bottom_cam_link">
      <self_collide>false</self_collide>
      <gravity>false</gravity>
      <pose>0 0 -0.05 0 1.5708 0</pose>
      <inertial>
        <mass>0.001</mass>
        <inertia><ixx>1e-6</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1e-6</iyy><iyz>0</iyz><izz>1e-6</izz></inertia>
      </inertial>
      <sensor name="bottom_camera" type="depth_camera">
        <gz_frame_id>bottom_cam_link</gz_frame_id>
        <always_on>1</always_on><update_rate>20</update_rate>
        <camera>
          <horizontal_fov>1.2217</horizontal_fov>
          <image><width>100</width><height>100</height><format>R_FLOAT32</format></image>
          <clip><near>0.2</near><far>3.0</far></clip>
        </camera>
        <visualize>true</visualize>
        <topic>bottom_depth_camera</topic>
      </sensor>
    </link>
    <joint name="bottom_cam_joint" type="fixed">
      <parent>base_link</parent><child>bottom_cam_link</child>
    </joint>

