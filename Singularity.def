Bootstrap: localimage
From: /scratch/YOURID/singularity/ros2_humble.sif

# ─────────────────────────────────────────────────────────────────────────────
# UAV Planner Stack — built on top of osrf/ros:humble-desktop-full
# Host: RHEL 9.4 + NVIDIA A40 (driver 575), Singularity 1.4.1
#
# Step 1 — pull base image (once):
#   mkdir -p /scratch/YOURID/singularity
#   singularity pull /scratch/YOURID/singularity/ros2_humble.sif \
#       docker://osrf/ros:humble-desktop-full
#
# Step 2 — build this image (update YOURID in From: above first):
#   cd /scratch/YOURID/irobot/px4_sim
#   singularity build --fakeroot uav_stack.sif Singularity.def
#
# Run:
#   singularity shell --nv uav_stack.sif
# ─────────────────────────────────────────────────────────────────────────────

%setup
    # Create mount point dirs required by NUS server bind mounts
    mkdir -p ${SINGULARITY_ROOTFS}/app1
    mkdir -p ${SINGULARITY_ROOTFS}/scratch
    mkdir -p ${SINGULARITY_ROOTFS}/home/svu

%post
    export DEBIAN_FRONTEND=noninteractive
    export ROS_DISTRO=humble

    # ── Gazebo Harmonic + ROS2 bridge ─────────────────────────────────────────
    curl -sSL https://packages.osrfoundation.org/gazebo.gpg \
        -o /usr/share/keyrings/pkgs-osrf-archive-keyring.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/pkgs-osrf-archive-keyring.gpg] \
        http://packages.osrfoundation.org/gazebo/ubuntu-stable jammy main" \
        > /etc/apt/sources.list.d/gazebo-stable.list

    apt-get update && apt-get install -y \
        gz-harmonic \
        ros-humble-ros-gzharmonic \
        && rm -rf /var/lib/apt/lists/*

    # ── ROS2 packages needed by planner_ws ───────────────────────────────────
    apt-get update && apt-get install -y \
        ros-humble-pcl-ros \
        ros-humble-pcl-conversions \
        ros-humble-octomap-ros \
        ros-humble-octomap-server \
        ros-humble-octomap-msgs \
        ros-humble-tf2-eigen \
        ros-humble-tf2-geometry-msgs \
        && rm -rf /var/lib/apt/lists/*

    # ── Build tools ───────────────────────────────────────────────────────────
    apt-get update && apt-get install -y \
        cmake ninja-build \
        python3-colcon-common-extensions \
        && rm -rf /var/lib/apt/lists/*

    # ── PX4 build toolchain ───────────────────────────────────────────────────
    apt-get update && apt-get install -y \
        gcc-arm-none-eabi \
        libxml2-utils \
        && rm -rf /var/lib/apt/lists/*

    pip3 install --no-cache-dir \
        "empy==3.3.4" \
        pyros-genmsg \
        packaging \
        jinja2 \
        jsonschema \
        numpy \
        toml \
        pyyaml

    # ── Micro XRCE-DDS Agent build deps ──────────────────────────────────────
    apt-get update && apt-get install -y \
        libasio-dev \
        libtinyxml2-dev \
        && rm -rf /var/lib/apt/lists/*

    apt-get clean

%environment
    export LANG=en_US.UTF-8
    export ROS_DISTRO=humble
    source /opt/ros/humble/setup.bash

%labels
    ROS2 humble
    Gazebo harmonic
    Base osrf/ros:humble-desktop-full

%help
    UAV planner stack: ROS2 Humble + Gazebo Harmonic.
    Host $HOME is auto-mounted — workspaces in ~/irobot/ are directly accessible.

    First-time setup inside container:
      1. cd ~/irobot/px4_sim && ./setup.sh
      2. cd ~/irobot/px4_autopilot/PX4-Autopilot
         PX4_GZ_WORLD=indoor_obstacle make px4_sitl gz_f450
      3. cd ~/irobot/px4_autopilot/Micro-XRCE-DDS-Agent
         mkdir build && cd build && cmake .. && make -j$(nproc)
      4. cd ~/irobot/px4_ros2_ws && colcon build
         cd ~/irobot/planner_ws  && colcon build

    Daily use:
      singularity shell --nv uav_stack.sif
      cd ~/irobot/px4_sim && ./run_sim.sh
