Bootstrap: docker
From: ubuntu:22.04

# ─────────────────────────────────────────────────────────────────────────────
# UAV Planner Stack — Singularity container
# Host: RHEL 9.4 + NVIDIA A40 (driver 575), Singularity 1.4.1
# Container: Ubuntu 22.04 + ROS2 Humble + Gazebo Harmonic
#
# Build:
#   singularity build uav_stack.sif Singularity.def
#
# Run (with GPU + display):
#   singularity shell --nv uav_stack.sif
# ─────────────────────────────────────────────────────────────────────────────

%post
    export DEBIAN_FRONTEND=noninteractive
    export TZ=Asia/Singapore

    # ── Base system ───────────────────────────────────────────────────────────
    apt-get update && apt-get install -y \
        locales curl wget gnupg2 lsb-release \
        software-properties-common ca-certificates \
        build-essential cmake ninja-build git \
        python3-pip python3-dev python3-colcon-common-extensions \
        python3-vcstool python3-future \
        libssl-dev libffi-dev \
        && rm -rf /var/lib/apt/lists/*

    locale-gen en_US.UTF-8

    # ── ROS2 Humble ───────────────────────────────────────────────────────────
    curl -sSL https://raw.githubusercontent.com/ros/rosdistro/master/ros.key \
        -o /usr/share/keyrings/ros-archive-keyring.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/ros-archive-keyring.gpg] \
        http://packages.ros.org/ros2/ubuntu jammy main" \
        > /etc/apt/sources.list.d/ros2.list

    apt-get update && apt-get install -y \
        ros-humble-desktop \
        ros-humble-ros-dev-tools \
        ros-humble-pcl-ros \
        ros-humble-pcl-conversions \
        ros-humble-octomap-ros \
        ros-humble-octomap-server \
        ros-humble-octomap-msgs \
        ros-humble-tf2-ros \
        ros-humble-tf2-eigen \
        ros-humble-tf2-geometry-msgs \
        && rm -rf /var/lib/apt/lists/*

    # ── Gazebo Harmonic + ROS bridge ──────────────────────────────────────────
    curl -sSL https://packages.osrfoundation.org/gazebo.gpg \
        -o /usr/share/keyrings/pkgs-osrf-archive-keyring.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/pkgs-osrf-archive-keyring.gpg] \
        http://packages.osrfoundation.org/gazebo/ubuntu-stable jammy main" \
        > /etc/apt/sources.list.d/gazebo-stable.list

    apt-get update && apt-get install -y \
        gz-harmonic \
        ros-humble-ros-gzharmonic \
        && rm -rf /var/lib/apt/lists/*

    # ── PX4 build toolchain ───────────────────────────────────────────────────
    apt-get update && apt-get install -y \
        gcc-arm-none-eabi \
        libxml2-utils \
        && rm -rf /var/lib/apt/lists/*

    pip3 install --no-cache-dir \
        "empy==3.3.4" \
        pyros-genmsg \
        packaging \
        jinja2 \
        jsonschema \
        numpy \
        toml \
        pyyaml

    # ── Micro XRCE-DDS Agent build deps ──────────────────────────────────────
    # (agent is built from source in $HOME — only deps needed here)
    apt-get update && apt-get install -y \
        libasio-dev \
        libtinyxml2-dev \
        && rm -rf /var/lib/apt/lists/*

%environment
    export LANG=en_US.UTF-8
    export LC_ALL=en_US.UTF-8
    export TZ=Asia/Singapore

    # ROS2
    source /opt/ros/humble/setup.bash

    # Gazebo: tell it where PX4 models/worlds live (set after setup.sh runs)
    # GZ_SIM_RESOURCE_PATH is extended in run_sim.sh at runtime

%labels
    Maintainer shantam.sharma98@gmail.com
    ROS2 humble
    Gazebo harmonic
    NVIDIA_driver_min 575

%help
    UAV planner stack: ROS2 Humble + Gazebo Harmonic on Ubuntu 22.04.
    Host $HOME is auto-mounted — workspaces in ~/irobot/ are directly accessible.

    First-time setup inside container:
      1. Run setup.sh to install custom PX4 files:
            cd ~/irobot/px4_sim && ./setup.sh
      2. Build PX4 SITL:
            cd ~/irobot/px4_autopilot/PX4-Autopilot
            PX4_GZ_WORLD=indoor_obstacle make px4_sitl gz_f450
      3. Build Micro XRCE-DDS Agent:
            cd ~/irobot/px4_autopilot/Micro-XRCE-DDS-Agent
            mkdir build && cd build && cmake .. && make -j$(nproc)
      4. Build ROS2 workspaces:
            cd ~/irobot/px4_ros2_ws && colcon build
            cd ~/irobot/planner_ws  && colcon build

    Daily use:
      singularity shell --nv uav_stack.sif
      cd ~/irobot/px4_sim && ./run_sim.sh
